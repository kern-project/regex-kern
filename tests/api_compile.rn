//! Compile-time coverage for README-shaped regex flows.

use base.mem.alloc.{Allocator, gpa};
use regex;
use sys.mem.page;

enum AppError {
    Regex: regex.Error,
}

// Mirrors the README flow so documentation examples stay compile-checked.
fn app(gpa: &mut Allocator) void!AppError {
    let pattern = "vk[A-Z][A-Za-z0-9_]*";
    let re = pattern.compile_regex(gpa)
        .map_err([](err: regex.Error) AppError { return .{ Regex: err }; })
        .!..&;
    defer re.deinit(gpa);

    let found = re.find("call vkCreateInstance before vkCreateDevice", gpa)
        .map_err([](err: regex.Error) AppError { return .{ Regex: err }; })
        .!;
    _ = found;

    let ok = pattern.matches_regex("vkCreateInstance", gpa)
        .map_err([](err: regex.Error) AppError { return .{ Regex: err }; })
        .!;
    _ = ok;
    let spans = pattern.find_all_regex("vkCreateInstance vkCreateDevice", gpa)
        .map_err([](err: regex.Error) AppError { return .{ Regex: err }; })
        .!..&;
    defer spans.deinit(gpa);
    return .{ Ok: {} };
}

// Keeps process exit handling at the outer boundary.
fn main() i32 {
    let page = page()..&;
    let gpa = gpa().on(page)..&;
    defer gpa.deinit();

    let .{ Ok: _ } = app(gpa) else return 1;
    return 0;
}
